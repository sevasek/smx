    {
      "parameters": {
        "jsCode": "// n8n Code Node — Filter to Previous Calendar Month (string dates)\n// Input: your full canonical dataset (date field is string \"YYYY-MM-DD\")\n// Output: only records from last calendar month\n\nconst now = new Date();\nconst currentYear = now.getFullYear();\nconst currentMonth = now.getMonth(); // 0-based (11 = Dec)\n\n// Calculate previous month and year\nlet prevYear = currentYear;\nlet prevMonth = currentMonth - 1;\nif (prevMonth < 0) {\n  prevMonth = 11;     // December of previous year\n  prevYear -= 1;\n}\n\n// Format as \"YYYY-MM\" string (e.g. \"2025-11\")\nconst prevMonthStr = `${prevYear}-${String(prevMonth + 1).padStart(2, '0')}`;\n\nreturn items.filter(item => {\n  const dateStr = item.json.date;\n  if (!dateStr || typeof dateStr !== 'string') return false;\n  // Check if date starts with \"YYYY-MM\" of previous month\n  return dateStr.startsWith(prevMonthStr);\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
