    {
      "parameters": {
        "jsCode": "// n8n Code Node — Filter to Last TWO Calendar Months (string dates)\n// Input: full canonical dataset (date field is string \"YYYY-MM-DD\")\n// Output: only records from the two most recent completed calendar months\n\nconst now = new Date();\n\n// --- Last month (previous calendar month) ---\nlet lastMonthYear = now.getFullYear();\nlet lastMonth = now.getMonth() - 1;  // previous month\nif (lastMonth < 0) {\n  lastMonth = 11;\n  lastMonthYear -= 1;\n}\nconst lastMonthStr = `${lastMonthYear}-${String(lastMonth + 1).padStart(2, '0')}`; // e.g. \"2025-11\"\n\n// --- Month before last ---\nlet twoMonthsAgoYear = lastMonthYear;\nlet twoMonthsAgo = lastMonth - 1;\nif (twoMonthsAgo < 0) {\n  twoMonthsAgo = 11;\n  twoMonthsAgoYear -= 1;\n}\nconst twoMonthsAgoStr = `${twoMonthsAgoYear}-${String(twoMonthsAgo + 1).padStart(2, '0')}`; // e.g. \"2025-10\"\n\nreturn items.filter(item => {\n  const dateStr = item.json.date;\n  if (!dateStr || typeof dateStr !== 'string') return false;\n\n  // Keep only dates that start with either of the two target months\n  return dateStr.startsWith(lastMonthStr) || dateStr.startsWith(twoMonthsAgoStr);\n});"
      },
      "type": "n8n-nodes-base.code",
