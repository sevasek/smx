    {
      "parameters": {
        "jsCode": "// n8n Code Node — Filter to Last 7 Days (strictly past & present, no future dates)\n// Input: items with .json.date as \"YYYY-MM-DD\"\n// Output: only the last 7 calendar days, never includes future dates\n\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);                    // start of today\nconst sevenDaysAgo = new Date(today);\nsevenDaysAgo.setDate(today.getDate() - 7);    // 7 days ago, same time\n\nconst todayStr = today.toISOString().split('T')[0];           // \"2025-12-03\"\nconst sevenDaysAgoStr = sevenDaysAgo.toISOString().split('T')[0]; // \"2025-11-26\"\n\nreturn items.filter(item => {\n  const dateStr = item.json.date;\n  \n  // Must be a valid string date\n  if (!dateStr || typeof dateStr !== 'string') return false;\n  \n  // Must be >= 7 days ago AND <= today (blocks any future dates)\n  return dateStr >= sevenDaysAgoStr && dateStr <= todayStr;\n});"
      },
